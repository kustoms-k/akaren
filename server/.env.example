# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — keep this private and never change it in prod
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── AI Analysis (Anthropic Claude) ───────────────────────────────────────────
# Required if switching from mock analysis to real Claude API
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Routing & Geocoding (OpenRouteService) ────────────────────────────────────
# HGV truck-optimised routing + Swedish geocoding
# Free tier: 2,000 req/day — https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# ── Trafikverket (Swedish Road Authority) ────────────────────────────────────
# Live road conditions and traffic disruptions — free
# Register at: https://api.trafikinfo.trafikverket.se/Account/Register
TRAFIKVERKET_API_KEY=

# ── SMS — 46elks ─────────────────────────────────────────────────────────────
# Leave blank to run in simulation mode (SMS logged to console, not sent)
# Sign up at: https://46elks.se/
ELKS_USERNAME=
ELKS_PASSWORD=

# ── Fortnox (Swedish accounting integration) ─────────────────────────────────
# Register your app at: https://developer.fortnox.se
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
FORTNOX_REDIRECT_URI=http://localhost:3002/api/fortnox/callback
# URL of the client app — used for post-OAuth redirect
APP_URL=http://localhost:5173

# ── Encryption (Fortnox token storage) ───────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of stored Fortnox tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Automated backups (S3-compatible storage) ────────────────────────────────
# Leave all blank to disable backups (a warning will be logged on startup)
# Works with: AWS S3, Cloudflare R2, Backblaze B2, MinIO
BACKUP_ENCRYPTION_KEY=
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=akaren-backups
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002
# DB_PATH=./data/kemoffs.db   # default — override for custom location

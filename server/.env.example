# Anthropic (already required for AI analysis)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouteService — real HGV routing for Stockholm distances
# Free tier: 2 000 req/day, 40 req/min  →  https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# Trafikverket Open API — live Swedish road conditions and traffic alerts
# Register free at https://api.trafikinfo.trafikverket.se/Account/Register
TRAFIKVERKET_API_KEY=

# 46elks SMS — leave blank to run in simulation mode (SMS logged to console)
ELKS_USERNAME=
ELKS_PASSWORD=

# Fortnox OAuth integration
# Register your app at https://developer.fortnox.se to get these values
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
# The callback URL must match what you registered in the Fortnox developer portal
FORTNOX_REDIRECT_URI=http://localhost:3002/api/fortnox/callback
# Where to redirect the browser after OAuth (your client app URL)
APP_URL=http://localhost:5173

# Encryption key for storing Fortnox tokens at rest (32-byte hex = 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Automated backups (S3-compatible: AWS S3, Cloudflare R2, Backblaze B2, MinIO) ──
# Leave blank to disable backups (a warning will be logged on startup)

# AES-256-GCM backup encryption key (32-byte hex = 64 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_KEY=

# S3-compatible storage
S3_ENDPOINT=                   # omit for AWS S3 native; set for R2/B2/MinIO e.g. https://xxx.r2.cloudflarestorage.com
S3_REGION=auto                 # eu-central-1 for AWS, auto for R2
S3_BUCKET=akaren-backups
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional
PORT=3002
